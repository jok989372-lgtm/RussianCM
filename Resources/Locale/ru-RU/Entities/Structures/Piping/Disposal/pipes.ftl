ent-DisposalHolder = держатель утилизации

ent-DisposalPipeBroken = сломанная труба утилизации
    .desc = ББП (большая сломанная труба).

ent-DisposalPipe = труба утилизации
    .desc = Большой сегмент трубы, используемый для строительства систем утилизации.

ent-DisposalTagger = маркировщик труб утилизации
    .desc = Труба, которая помечает объекты для маршрутизации.

ent-DisposalSignaller = сигнализатор утилизации
    .desc = Труба, которая излучает сигнал, когда предмет проходит через неё.

ent-DisposalTrunk = ствол трубы утилизации
    .desc = Ствол трубы, используемый в качестве точки входа в системы утилизации.

ent-DisposalRouter = маршрутизатор утилизации
    .desc = Трёхсторонний маршрутизатор.

ent-DisposalRouterFlipped = { ent-DisposalRouter }
    .desc = {ent-DisposalRouter.desc}

ent-DisposalJunction = узел утилизации
    .desc = Трёхсторонний узел. Стрелка указывает, где выходят предметы.

ent-DisposalJunctionFlipped = { ent-DisposalJunction }
    .desc = { ent-DisposalJunction.desc }

ent-DisposalYJunction = Y-образный узел утилизации
    .desc = Трёхсторонний узел с дополнительной точкой выхода.

ent-DisposalXJunction = X-образный узел утилизации
    .desc = Четырёхсторонний узел. Стрелка указывает, где выходят предметы.

ent-DisposalBend = изгиб трубы утилизации
    .desc = Труба, изогнутая под углом 90 градусов.

ent-DisposalSignalRouter = сигнальный маршрутизатор утилизации
    .desc = Трёхсторонний маршрутизатор, управляемый сигналом.

