command-set-entity-xeno-ally-status = Sets the hive ally status of the provided entity.
command-set-entity-xeno-ally-status-help = Usage: sethiveally <ent> <hive entity> <true/false>

command-set-faction-xeno-ally-status = Sets the hive ally status of the provided faction.
command-set-faction-xeno-ally-status-help = Usage: sethivefactionally <NpcFactionPrototype id> <hive entity> <true/false>

command-clear-xeno-ally-ents = Removes the hive ally status of all entities (not factions) allied to a hive.
command-clear-xeno-ally-ents-help = Usage: clearhiveallies <hive entity>