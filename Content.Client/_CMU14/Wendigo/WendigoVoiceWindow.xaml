<DefaultWindow xmlns="https://spacestation14.io"
               Title="Wendigo Voice Mimicry"
               MinSize="500 500"
               SetSize="500 500">

    <BoxContainer Orientation="Horizontal" VerticalExpand="True" Margin="8" SeparationOverride="8">

        <!-- Left: category buttons -->
        <BoxContainer
            Name="CategoryList"
            Orientation="Vertical"
            MinWidth="120"
            SeparationOverride="3" />

        <!-- Right: search + line list -->
        <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="6">

            <LineEdit
                Name="SearchBar"
                PlaceHolder="Search..."
                HorizontalExpand="True" />

            <ScrollContainer
                VerticalExpand="True"
                HScrollEnabled="False">
                <BoxContainer
                    Name="LineList"
                    Orientation="Vertical"
                    SeparationOverride="3"
                    HorizontalExpand="True" />
            </ScrollContainer>

        </BoxContainer>

    </BoxContainer>

</DefaultWindow>
