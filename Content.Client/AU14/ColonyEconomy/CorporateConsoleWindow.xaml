<controls:CorporateConsoleWindow
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Content.Client.AU14.ColonyEconomy"
    MinSize="480 480">
    <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="8">
            <Label Name="CorporateBudgetLabel" Access="Public"
                   StyleClasses="LabelHeading" Margin="0 4" />

            <!-- Withdraw -->
            <Label Name="WithdrawCashLabel" Margin="0 4" />
            <Label Name="WithdrawTaxNote" Access="Public"
                   StyleClasses="LabelSubText" Margin="0 2" />
            <BoxContainer Orientation="Horizontal" SeparationOverride="4" Margin="0 2">
                <Button Name="Withdraw100" Access="Public"
                        HorizontalExpand="True" Margin="2 0" />
                <Button Name="Withdraw250" Access="Public"
                        HorizontalExpand="True" Margin="2 0" />
                <Button Name="Withdraw500" Access="Public"
                        HorizontalExpand="True" Margin="2 0" />
            </BoxContainer>

            <!-- Transit Tariff -->
            <Label Name="TransitTariffSectionLabel" Margin="0 6" />
            <Label Name="CurrentTariffLabel" Access="Public"
                   Margin="0 2" />
            <Label Name="TariffDescLabel"
                   StyleClasses="LabelSubText" Margin="0 2" />
            <BoxContainer Orientation="Horizontal" SeparationOverride="4" Margin="0 4">
                <Label Name="TariffInputLabel" />
                <LineEdit Name="TariffInput" Access="Public"
                          HorizontalExpand="True" SizeFlagsStretchRatio="2" />
                <Button Name="SetTariffButton" Access="Public" />
            </BoxContainer>

            <!-- Economy Overview -->
            <Label Name="EconomyOverviewLabel" Margin="0 6" />
            <BoxContainer Name="EconomyStatusPanel" Access="Public" Orientation="Vertical" Margin="4 2" />

            <!-- Third Party -->
            <Label Name="ThirdPartySectionLabel" Margin="0 6" />
            <Button Name="OpenThirdPartyBtn" Access="Public"
                    HorizontalExpand="True" Margin="0 4" />
        </BoxContainer>
    </ScrollContainer>
</controls:CorporateConsoleWindow>

